# Puerto donde el MCP server escucha
MCP_PORT=4101

# Base URL del API iqtekgolf que el MCP consume
# En prod: https://api.iqtekgolf.innovix.com.do
# En dev: http://localhost:4001
API_BASE_URL=http://localhost:4001

# Timeout (ms) para llamadas al API
API_TIMEOUT_MS=15000

# Nivel de log (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Si "true", el MCP rechaza requests sin Authorization header.
# Si "false" (solo para desarrollo), permite requests sin auth — útil para testing manual.
REQUIRE_AUTH=true
