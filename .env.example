# URL del API consumido (provisto por el administrador, por canal privado)
API_BASE_URL=

# JWT del staff (provisto por el administrador, por canal privado)
STAFF_JWT=

# Puerto del modo HTTP (solo si usás server.js en vez del stdio)
MCP_PORT=4101

# Timeout (ms) para llamadas HTTP al API
API_TIMEOUT_MS=15000

# Nivel de log (trace, debug, info, warn, error, fatal). Va a stderr.
LOG_LEVEL=info

# Solo aplica al modo HTTP — rechaza requests sin Authorization header
REQUIRE_AUTH=true
