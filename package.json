{
  "name": "iqtek-mcp-golf-platform",
  "version": "1.0.0",
  "description": "MCP server productivo del iQtek Golf — cliente HTTP fino del API que expone tools de pairing, foursomes y scoring para que Claude pueda operar el torneo en vivo.",
  "main": "dist/server.js",
  "bin": {
    "iqtek-mcp-golf-platform": "dist/server-stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:stdio": "node dist/server-stdio.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "test -d dist || tsc"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
